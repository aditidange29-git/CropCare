# CropCare Backend — environment variables
# Copy this file to .env and fill in your own values.
# See architecture/02_TRD.md for where each free-tier credential comes from.
# NEVER commit .env to git — it is in .gitignore.

PORT=4000

# ── Supabase (free tier) ──────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not the anon key) — backend needs full DB access.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Gemini Vision API (free tier) ────────────────────────────────────────────
# Google AI Studio → Get API Key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Any long random string. Used to sign/verify all JWTs.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max diagnoses per user per day — protects free-tier Gemini quota.
# See architecture/07_Architecture.md §6
DAILY_DIAGNOSIS_LIMIT_PER_USER=20

# ── Node env ─────────────────────────────────────────────────────────────────
NODE_ENV=development
