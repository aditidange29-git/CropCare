{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "cropcare-shared": ["../shared/index.ts"],
      "cropcare-shared/*": ["../shared/*"]
    }
  },
  "include": ["src"]
}
