# CropCare Frontend — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# All VITE_* variables are embedded into the JS bundle at build time.
# Do NOT put secrets here — only public-safe values.
# The Supabase anon key and Gemini key belong in the BACKEND .env only.

# Backend API base URL — used by src/services/api.ts
# Local development:
VITE_API_BASE_URL=http://localhost:4000/api/v1
# Deployed backend (update when you deploy to Render):
# VITE_API_BASE_URL=https://your-cropcare-backend.onrender.com/api/v1
